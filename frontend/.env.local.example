# SignFlow Frontend — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.

# ── Backend API URL ───────────────────────────────────────────────────────────
# This is the ONLY backend-adjacent config the frontend ever sees.
# No Setu credentials, no client IDs, no secrets — ever.
# NEXT_PUBLIC_ prefix means this value is bundled client-side.
# Double-check that nothing sensitive ever gets this prefix.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ── Clerk (Auth) ──────────────────────────────────────────────────────────────
# Publishable key from Clerk dashboard → API Keys (starts with pk_test_ or pk_live_)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
