# SignFlow Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git. This file (.env.example) is safe to commit — it has no real values.

# ── Setu API Credentials ──────────────────────────────────────────────────────
# These are the ONLY credentials in the entire codebase.
# They must never appear in any frontend file or in any NEXT_PUBLIC_ variable.
SETU_CLIENT_ID=
SETU_CLIENT_SECRET=
SETU_PRODUCT_INSTANCE_ID=
# Sandbox: https://dg-sandbox.setu.co  |  Production: https://dg.setu.co
SETU_BASE_URL=https://dg-sandbox.setu.co

# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:password@localhost:5432/signflow

# ── CORS ──────────────────────────────────────────────────────────────────────
# Only this origin is allowed to call the backend. Never use * in production.
FRONTEND_URL=http://localhost:3000

# ── File Validation ───────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10

# ── Environment ───────────────────────────────────────────────────────────────
# Valid values: development | production
# In production, verbose error details are suppressed in API responses.
ENVIRONMENT=development

# ── Clerk (Auth) ──────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_HdiHNK5kQZSftvAnAc3s8ABxJImnQ2LIR2BiARPJFc
# JWKS URL: https://<your-instance>.clerk.accounts.dev/.well-known/jwks.json
# Found in Clerk dashboard → API Keys → Advanced
CLERK_JWKS_URL=https://steady-dory-48.clerk.accounts.dev/.well-known/jwks.json

# ── Future: Webhook Support (not used in MVP) ─────────────────────────────────
# Uncomment and fill in when implementing T6.2 (Setu webhook support)
# SETU_WEBHOOK_SECRET=
